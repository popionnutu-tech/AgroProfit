{
  "name": "agroaplicati",
  "version": "1.0.0",
  "description": "MVP agro: Telegram bot for goods intake and web dashboard.",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/bot-only.js",
    "start:server": "node src/server.js",
    "dev": "node --watch src/server.js",
    "test": "node --test --test-isolation=none test/*.test.js",
    "backups:list": "node scripts/runtime-backup-cli.js list",
    "backups:restore": "node scripts/runtime-backup-cli.js restore"
  },
  "keywords": [
    "agro",
    "telegram",
    "dashboard"
  ],
  "license": "MIT",
  "dependencies": {
    "@supabase/supabase-js": "^2.49.8",
    "dotenv": "^16.4.5",
    "express": "^4.21.2",
    "multer": "^2.0.1",
    "telegraf": "^4.16.3"
  }
}
